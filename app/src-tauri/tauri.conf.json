{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Hypixel Security",
  "version": "0.1.0",
  "identifier": "com.emevonlou.minecrafthypixelsecurity",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Minecraft Hypixel Security",
        "width": 1100,
        "height": 760,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
